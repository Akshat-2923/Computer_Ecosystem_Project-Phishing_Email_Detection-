ct_phishing(text):\n","    # 1. Preprocess and Tokenize\n","    inputs = tokenizer(text, return_tensors=\"pt\", padding=True, truncation=True, max_length=128).to(device)\n","\n","    # 2. Get Prediction\n","    with torch.no_grad():\n","        outputs = model(**inputs)\n","        probabilities = torch.nn.functional.softmax(outputs.logits, dim=-1)\n","        prediction = torch.argmax(probabilities, dim=-1).item()\n","        confidence = probabilities[0][prediction].item()\n","\n","    label = \"PHISHING\" if prediction == 1 else \"SAFE\"\n","    return f\"Result: {label} ({confidence*100:.2f}% confidence)\"\n","\n","# 3. Test on a tricky Hinglish scam\n","test_text = \"Aapka SBI account suspend ho jayega. Abhi apna OTP share karein.\"\n","print(f\"Testing: {test_text}\")\n","print(predict_phishing(test_text))\n","\n","# 4. Test on a safe Hinglish message\n","safe_text = \"Hi, kal college ki meeting 3 baje hai. Sab log time par aana.\"\n","print(f\"\\nTesting: {safe_text}\")\n","print(predict_phishing(safe_text))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0Gcr0-Jy9E8i","executionInfo":{"status":"ok","timestamp":1772866015576,"user_tz":-330,"elapsed":36,"user":{"displayName":"Akshat Dwivedi","userId":"14744536690966818734"}},"outputId":"a30c96b7-cbec-4e0e-8ef4-6a04c2c997f5"},"execution_count":24,"outputs":[{"output_type":"stream","name":"stdout","text":["Testing: Aapka SBI account suspend ho jayega. Abhi apna OTP share karein.\n","Result: PHISHING (95.87% confidence)\n","\n","Testing: Hi, kal college ki meeting 3 baje hai. Sab log time par aana.\n","Result: SAFE (100.00% confidence)\n"]}]},{"cell_type":"code","source":["from transformers import pipeline\n","import shap\n","\n","# 1. Create a text-classification pipeline\n","# This makes the model easier for SHAP to understand\n","pred_pipeline = pipeline(\n","    \"text-classification\",\n","    model=model,\n","    tokenizer=tokenizer,\n","    device=0 if torch.cuda.is_available() else -1